  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "lint": "oxlint",
    "preview": "vite preview",
    "release": "npm version patch && git push && git push --tags"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
